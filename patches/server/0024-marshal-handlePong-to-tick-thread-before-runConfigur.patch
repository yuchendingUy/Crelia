 <dingyuchen@dingyuchendeMacBook-Pro.local>
Date: Sat, 13 Jun 2026 02:35:54 +0800
Subject: [PATCH] marshal handlePong to tick thread before runConfiguration
 (Bukkit sync-event rule under Folia)


diff --git a/src/main/java/net/minecraft/server/network/ServerConfigurationPacketListenerImpl.java b/src/main/java/net/minecraft/server/network/ServerConfigurationPacketListenerImpl.java
index d68e7d38638b1eeadcb93fb46130b3d41722402a..c8a6aadd6e94535bcdbdaf292f8a896d25b4d50e 100644
--- a/src/main/java/net/minecraft/server/network/ServerConfigurationPacketListenerImpl.java
+++ b/src/main/java/net/minecraft/server/network/ServerConfigurationPacketListenerImpl.java
@@ -149,6 +149,10 @@ public class ServerConfigurationPacketListenerImpl extends ServerCommonPacketLis
 
     @Override
     public void handlePong(net.minecraft.network.protocol.common.ServerboundPongPacket packet) {
+        // Crelia: 官方 Neo 在 netty 线程直接跑 runConfiguration 没事,但我们的 runConfiguration 里有
+        // CraftBukkit 的 PlayerLinksSendEvent(同步事件只准在 tick 线程发),必须先调度回正确线程,
+        // 写法照抄本类 handleConfigurationFinished。
+        PacketUtils.ensureRunningOnSameThread(packet, this, (BlockableEventLoop) this.server);
         super.handlePong(packet);
         // Neo: During startConfiguration() we send a ping with id 0, if we get a pong back, we initiate the connection.
         // Crelia: 这是把 startConfiguration 里发出的 ping(0) 接回来的另一半——漏了它,配置阶段永远不会推进(实测卡"正在加入")。
