+    doLast {
+        val jarFile = archiveFile.get().asFile
+        val strippedJar = temporaryDir.resolve(jarFile.name)
+        val seenEntries = mutableSetOf<String>()
+
+        ZipInputStream(jarFile.inputStream().buffered()).use { input ->
+            ZipOutputStream(strippedJar.outputStream().buffered()).use { output ->
+                var entry = input.nextEntry
+                while (entry != null) {
+                    if (!entry.isDirectory && seenEntries.add(entry.name)) {
+                        val strippedEntry = ZipEntry(entry.name)
+                        strippedEntry.time = entry.time
+                        output.putNextEntry(strippedEntry)
+                        input.copyTo(output)
+                        output.closeEntry()
+                    }
+                    input.closeEntry()
+                    entry = input.nextEntry
+                }
+            }
+        }
+
+        strippedJar.copyTo(jarFile, overwrite = true)
+    }
