+                            BlockState state = section.getBlockState(x, y, z);
+                            mutablePos.setWithOffset(sectionOrigin, x, y, z);
+                            if (roughFilter.test(state) && fineFilter.test(state, mutablePos)) {
+                                consumer.accept(mutablePos, state);
+                            }
+                        }
+                    }
