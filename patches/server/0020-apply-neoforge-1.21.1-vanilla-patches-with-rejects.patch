+                CatVariant.BLACK,
+                CatVariant.RED,
+                CatVariant.SIAMESE,
+                CatVariant.BRITISH_SHORTHAIR,
+                CatVariant.CALICO,
+                CatVariant.PERSIAN,
+                CatVariant.RAGDOLL,
