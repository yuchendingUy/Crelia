+    protected LootTable.Builder createCandleDrops(Block candle) {
+        return LootTable.lootTable()
+            .withPool(
+                LootPool.lootPool()
+                    .setRolls(ConstantValue.exactly(1.0F))
+                    .add(
+                        (LootPoolEntryContainer.Builder<?>)this.applyExplosionDecay(
