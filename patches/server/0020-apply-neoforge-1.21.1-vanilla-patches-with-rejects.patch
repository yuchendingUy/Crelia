+                            LootItem.lootTableItem(candle)
+                                .apply(
+                                    List.of(2, 3, 4),
+                                    candles -> SetItemCountFunction.setCount(ConstantValue.exactly((float)candles.intValue()))
+                                            .when(
+                                                LootItemBlockStatePropertyCondition.hasBlockStateProperties(candle)
