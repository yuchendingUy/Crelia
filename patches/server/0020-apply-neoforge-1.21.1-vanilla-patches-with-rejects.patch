+
+    public EnderDragonPart(EnderDragon owner, String name, float width, float height) {
+        super(owner.getType(), owner.level());
+        this.size = EntityDimensions.scalable(width, height);
+        this.refreshDimensions();
+        this.parentMob = owner;
+        this.name = name;
+    }
+
+    @Override
+    protected void defineSynchedData(SynchedEntityData.Builder builder) {
+    }
+
+    @Override
+    protected void readAdditionalSaveData(CompoundTag nbt) {
+    }
+
+    @Override
+    protected void addAdditionalSaveData(CompoundTag nbt) {
+    }
+
+    @Override
+    public boolean isPickable() {
+        return true;
+    }
+
+    @Nullable
+    @Override
+    public ItemStack getPickResult() {
+        return this.parentMob.getPickResult();
+    }
+
+    @Override
+    public boolean hurt(DamageSource source, float amount) {
+        return !this.isInvulnerableTo(source) && this.parentMob.hurt(this, source, amount);
+    }
+
+    @Override
+    public boolean is(Entity entity) {
+        return this == entity || this.parentMob == entity;
+    }
+
+    @Override
+    public Packet<ClientGamePacketListener> getAddEntityPacket(ServerEntity entityTrackerEntry) {
+        throw new UnsupportedOperationException();
+    }
+
+    @Override
+    public EntityDimensions getDimensions(Pose pose) {
+        return this.size;
+    }
+
+    @Override
+    public boolean shouldBeSaved() {
+        return false;
+    }
+}
